{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/draft",            "destination": "/api/draft.js" },
    { "source": "/api/stats",            "destination": "/api/stats.js" },
    { "source": "/api/checkout",         "destination": "/api/checkout.js" },
    { "source": "/api/webhook",          "destination": "/api/webhook.js" },
    { "source": "/api/channel-status",      "destination": "/api/channel-status.js" },
    { "source": "/api/fetch-emails",        "destination": "/api/fetch-emails.js" },
    { "source": "/api/connect-gmail",       "destination": "/api/connect-gmail.js" },
    { "source": "/api/gmail-webhook",       "destination": "/api/gmail-webhook.js" },
    { "source": "/api/connect-instagram",   "destination": "/api/connect-instagram.js" },
    { "source": "/api/instagram-webhook",   "destination": "/api/instagram-webhook.js" },
    { "source": "/api/whatsapp-webhook", "destination": "/api/whatsapp-webhook.js" },
    { "source": "/privacy",               "destination": "/privacy.html" },
    { "source": "/dashboard",            "destination": "/dashboard.html" },
    { "source": "/app",                  "destination": "/dashboard.html" },
    { "source": "/contact",              "destination": "/contact.html" }
  ]
}
