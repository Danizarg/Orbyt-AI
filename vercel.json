{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/draft",              "dest": "/api/draft.js" },
    { "src": "/api/stats",              "dest": "/api/stats.js" },
    { "src": "/api/connect-gmail",      "dest": "/api/connect-gmail.js" },
    { "src": "/api/gmail-webhook",      "dest": "/api/gmail-webhook.js" },
    { "src": "/api/whatsapp-webhook",   "dest": "/api/whatsapp-webhook.js" },
    { "src": "/",                       "dest": "/public/index.html" },
    { "src": "/(.*)",                   "dest": "/public/$1" }
  ]
}
