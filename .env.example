# Orbyt AI — Environment Variables
# Copy this to .env.local for local development. Set these in Vercel Dashboard for production.

# ── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_ANON_KEY=            # Public anon key (same one in dashboard.html)

# ── App ───────────────────────────────────────────────────────────────────
APP_URL=https://orbytai.org   # Production URL (used for CORS + OAuth redirects)

# ── Airtable ──────────────────────────────────────────────────────────────
AIRTABLE_API_KEY=             # Personal access token from airtable.com/create/tokens
AIRTABLE_BASE_ID=             # Base ID (starts with "app...")

# ── AI ────────────────────────────────────────────────────────────────────
GROQ_API_KEY=                 # API key from console.groq.com

# ── Gmail OAuth ───────────────────────────────────────────────────────────
GMAIL_CLIENT_ID=              # Google Cloud Console → Credentials
GMAIL_CLIENT_SECRET=          # Google Cloud Console → Credentials
GMAIL_REDIRECT_URI=https://orbytai.org/api/connect-gmail
GMAIL_PUBSUB_TOPIC=           # Optional: projects/PROJECT/topics/TOPIC for push notifications

# ── Outlook OAuth ─────────────────────────────────────────────────────────
OUTLOOK_CLIENT_ID=            # Azure Portal → App registrations
OUTLOOK_CLIENT_SECRET=        # Azure Portal → Certificates & Secrets
OUTLOOK_REDIRECT_URI=https://orbytai.org/api/connect-gmail

# ── Instagram / Meta ──────────────────────────────────────────────────────
META_APP_ID=                  # Meta Developer Portal → App ID
META_APP_SECRET=              # Meta Developer Portal → App Secret (used for webhook signature verification)
META_REDIRECT_URI=https://orbytai.org/api/connect-instagram
META_VERIFY_TOKEN=            # Random string you choose for webhook verification

# ── Stripe ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=            # Stripe Dashboard → API keys → Secret key
STRIPE_WEBHOOK_SECRET=        # Stripe Dashboard → Webhooks → Signing secret (whsec_...)

# ── WhatsApp (WATI) ──────────────────────────────────────────────────────
WATI_API_URL=                 # e.g. https://live-server-XXXXX.wati.io
WATI_API_TOKEN=               # WATI Dashboard → API & Webhooks

# ── Business ──────────────────────────────────────────────────────────────
BUSINESS_CONTEXT=             # Optional: default business context for WhatsApp AI replies
